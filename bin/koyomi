#!/usr/bin/env ruby
# frozen_string_literal: true

# vim: filetype=ruby

lib = File.expand_path('lib', __dir__)
$LOAD_PATH.unshift(lib) unless $LOAD_PATH.include?(lib)

require 'himekuri/version'

# Zinbei module
module Koyomi
  module_function

  def version
	require 'himekuri'
  end

  def reiwa
	require 'himekuri'
  end

  def koyomi
	require 'himekuri'
  end

  def count
	require 'himekuri'
  end

  def start
	require 'himekuri'
  end
end

v = /\A[-][v]\z/
r = /\A[-][r]\z/
k = /\A[-][k]\z/
c = /\A[-][c]\z/

one = ARGV[0]

include Koyomi

if one.nil?
	HimekuriClass.new.himekuri_print
	HimekuriClass.new.count_print
	HimekuriClass.new.reiwa_print
	HimekuriClass.new.version
elsif one.match?(v)
	HimekuriClass.new.version
elsif one.match?(r)
	HimekuriClass.new.reiwa_print
elsif one.match?(k)
	HimekuriClass.new.himekuri_print
elsif one.match?(c)
	HimekuriClass.new.count_print
else
  puts 'そのオプションは存在しないかなどでbacktraceが流れています ! '
end

__END__
